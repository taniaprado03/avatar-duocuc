{
  "rewrites": [
    {
      "source": "/api/ideainmotion/:match*",
      "destination": "https://totem.ideainmotion.cl/:match*"
    },
    {
      "source": "/api/tickets/:match*",
      "destination": "https://cittsb.cl/asesor_totem/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
